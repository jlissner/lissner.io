{
  "name": "family-image-manager",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n ollama,server,ui \"ollama serve\" \"tsx watch server/src/index.ts\" \"vite --config ui/vite.config.ts\"",
    "dev:web": "concurrently -n server,ui \"tsx watch server/src/index.ts\" \"vite --config ui/vite.config.ts\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:ui": "vite --config ui/vite.config.ts",
    "build": "tsc -b && vite build --config ui/vite.config.ts",
    "start": "node server/dist/index.js",
    "clear-index": "curl -s -X POST http://localhost:3000/api/search/index/clear",
    "nuke": "tsx scripts/nuke-everything.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "servers": "bash scripts/list-servers.sh",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/client-ses": "^3.1010.0",
    "@canvas/image": "^2.0.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@vladmandic/human": "^3.3.6",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "exifr": "^7.1.3",
    "express": "^5.0.1",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "sharp": "^0.34.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0"
  }
}
