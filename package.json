{
  "name": "lissner.io",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "server/dist/index.js",
  "entry": "server/dist/index.js",
  "scripts": {
    "build": "tsc -b && vite build --config ui/vite.config.ts",
    "build:server": "tsc -b shared server",
    "clear-index": "tsx scripts/clear-search-index.ts",
    "dev": "concurrently -n ollama,server,ui -c yellow,blue,green \"ollama serve\" \"tsx watch server/src/index.ts\" \"vite --config ui/vite.config.ts\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:ui": "vite --config ui/vite.config.ts",
    "dev:web": "concurrently -n server,ui \"tsx watch server/src/index.ts\" \"vite --config ui/vite.config.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "host:local": "concurrently -n ollama,server,ui \"ollama serve\" \"tsx watch server/src/index.ts\" \"vite --config ui/vite.config.ts --host\"",
    "host": "npm run build && npm run host:build && npm run host:up",
    "host:build": "bash scripts/docker-compose.sh build --no-cache",
    "host:up": "bash scripts/docker-compose.sh up -d --wait",
    "host:down": "bash scripts/docker-compose.sh down",
    "host:pull": "bash scripts/docker-compose.sh exec ollama sh -lc 'ollama pull \"${OLLAMA_EMBED_MODEL:-nomic-embed-text}\" && ollama pull \"${OLLAMA_VISION_MODEL:-llava}\"'",
    "host:logs": "bash scripts/docker-compose.sh logs -f",
    "host:status": "bash scripts/docker-compose.sh ps",
    "host:config": "bash scripts/docker-compose.sh config -q",
    "validate": "npm run lint && npm test && npm run host:config",
    "deploy": "npm run validate && npm run host",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "nuke": "tsx scripts/nuke-everything.ts",
    "servers": "bash scripts/list-servers.sh",
    "start": "node server/dist/index.js",
    "test": "vitest run",
    "test:bdd": "npm run build:server && cucumber-js 'features/**/*.feature' --import tsx/esm --import 'features/support/test-env.ts' --import 'features/step-definitions/**/*.ts' --format progress"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1033.0",
    "@aws-sdk/client-ses": "3.1033.0",
    "@aws-sdk/lib-storage": "3.1033.0",
    "@tanstack/react-query": "5.91.3",
    "@tensorflow/tfjs-node": "4.22.0",
    "@vladmandic/human": "3.3.6",
    "better-sqlite3": "12.6.2",
    "cors": "2.8.5",
    "dotenv": "17.3.1",
    "exifr": "7.1.3",
    "express": "5.2.1",
    "jose": "^6.2.2",
    "multer": "2.1.1",
    "sharp": "0.34.5",
    "tiny-invariant": "1.3.3",
    "ws": "8.19.0",
    "yoctocolors": "^2.1.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.2",
    "@eslint/js": "10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.0",
    "@types/multer": "2.1.0",
    "@types/node": "24.1.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.0.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.4.0",
    "prettier": "3.8.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.9",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "4.1.4",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  }
}
