# ENV Variables that are commented out MUST be changed to a valid value

## Environment
NODE_ENV=development

## Server settings
DATA_DIR=./data
#SESSION_SECRET=123
#FIRST_ADMIN_EMAIL=admin@example.com
OLLAMA_VISION_MODEL=llava

## Ports and URLS
UI_PORT=5173
# Local dev: Ollama on this machine. Traefik-only hostnames (e.g. ollama.internal) do not resolve on the host or inside the app container unless you set up DNS; see HOST.md. Docker Compose pins app→Ollama to http://ollama:11434.
OLLAMA_HOST=http://127.0.0.1:11434
SERVER_PROTOCOL=http
SERVER_HOST=localhost
SERVER_PORT=3000

## AWS settings
# AWS_ACCESS_KEY_ID=someId
# AWS_SECRET_ACCESS_KEY=someKey
AWS_REGION=us-west-2
# S3_BUCKET=example-bucket-name
# SES_FROM_EMAIL=noreply@example.com

## feature flags
DATA_EXPLORER_ENABLED=false
SQL_EXPLORER_ENABLED=false
